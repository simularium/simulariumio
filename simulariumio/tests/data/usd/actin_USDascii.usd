def Material "actinShader1SG" (
    kind = "assembly"
)
{
    token outputs:surface.connect = </actinShader1SG/actinShader1.outputs:surface>

    def Shader "actinShader1"
    {
        uniform token info:id = "UsdPreviewSurface"
        color3f inputs:diffuseColor = (0.27199998, 0.8, 0.27199998)
        normal3f inputs:normal = (1, 1, 1)
        float inputs:roughness = 1
        int inputs:useSpecularWorkflow = 1
        token outputs:displacement
        token outputs:surface
    }
}

